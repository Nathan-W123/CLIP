# Base URL of the FastAPI STT service (no trailing slash). Use your Mac’s LAN IP for device/simulator.
EXPO_PUBLIC_API_URL=http://192.168.1.1:8000

# Supabase project URL and anon / publishable key (Project Settings → API).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
